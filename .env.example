# AgentsMap Runtime — public demo configuration
# Copy this file to .env for local portfolio/demo usage.
# This public version uses synthetic seed data and a synthetic demo worker only.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/agentmap
API_PORT=8080
WEB_DEV_PORT=5173
WEB_API_TARGET=http://127.0.0.1:8080

# Synthetic demo worker. It generates local demo payment events from data/demo/rows-demo.tsv.
DEMO_WORKER_POLL_MS=5000

# API/demo tuning
ACTIVITY_UI_ACTIVITY_DAYS=30
DISCOVERY_ENTITIES_CACHE_TTL_MS=120000
DISCOVERY_ENTITIES_PREWARM_MS=0
